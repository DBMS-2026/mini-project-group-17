# NexusEstate — Root .env Template
# Copy this to .env and fill in your values

# ── PostgreSQL ────────────────────────────────
DB_USER=postgres
DB_PASSWORD=12345678
DB_NAME=nexusestate
DB_HOST=localhost
DB_PORT=5432

# ── Backend ───────────────────────────────────
PORT=3001
JWT_SECRET=any_long_random_string_here

# ── Service URLs (local dev) ──────────────────
SWAP_ENGINE_URL=http://localhost:8001
AI_SERVICE_URL=http://localhost:8000

# ── Frontend (Next.js public env vars) ────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8000

# ─── Google Auth 2.0 ──────────────────────────────
# Needed for the backend to securely verify the token
GOOGLE_CLIENT_ID=402815349716-t22afoh0d2eviiasnjeodl7frebdit1v.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Needed for Next.js frontend to render the Google Login Button
NEXT_PUBLIC_GOOGLE_CLIENT_ID=402815349716-t22afoh0d2eviiasnjeodl7frebdit1v.apps.googleusercontent.com
